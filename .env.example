# Host and port where llama-server is running
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080

# Path to the directory containing llama-server executable
LLAMA_SERVER_DIR=

# Path to directory containing your .gguf model files
GGUF_DIR=

UI_HOST=127.0.0.1
UI_PORT=7860

# Set to 1 to create a public Gradio share link
UI_SHARE=0

# When UI_SHARE=1, keep this 0 unless you explicitly trust remote users
# to execute MCP tools on your machine
ALLOW_REMOTE_TOOLS=0

# Default context size for llama-server (tokens)
CTX_SIZE=4096

# GPU layers to offload (-1 = all, 0 = CPU only)
GPU_LAYERS=-1

# KV cache quantization for larger context windows (Requires Flash Attention)
KV_CACHE_TYPE_K=f16
KV_CACHE_TYPE_V=f16

# Set to 1 to allow MCP tool execution when UI_SHARE is enabled
ALLOW_REMOTE_TOOLS=0
